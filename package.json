{
  "name": "eternal-jam-session",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:worker": "wrangler deploy --dry-run --outdir=dist/worker",
    "dev": "vite build && wrangler dev",
    "dev:watch": "concurrently -k \"vite build --watch\" \"wrangler dev\"",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.40.0",
    "agents": "^0.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/node": "^22.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
